        }
      },
      "typeVersion": 1.2
    },
    {
      "id": "9b68e758-0524-43bf-90ef-5bc2904b9dfb",
      "name": "🔍 Filter – Due for Reminder",
      "type": "n8n-nodes-base.code",
      "position": [
        1904,
        3664
      ],
      "parameters": {
        "jsCode": "const now = Date.now();\nconst items = $input.all();\n\nconst toRemind = items.filter(item => {\n  const row = item.json;\n  if (!row['Appointment Date'] || !row['Appointment Time']) return false;\n  if (row['Status'] !== 'Booked') return false;\n\n  const dtStr = `${row['Appointment Date']}T${row['Appointment Time']}:00`;\n  const apptMs = new Date(dtStr).getTime();\n  const reminderMs = apptMs - 24 * 60 * 60 * 1000;\n\n  // ⬇️ TEST MODE: passes anything in next 7 days instead of exact 1hr window\n  return reminderMs >= now && reminderMs < now + 7 * 24 * 60 * 60 * 1000;\n});\n\nif (toRemind.length === 0) return [];\nreturn toRemind.map(item => ({ json: item.json }));"
      },
      "typeVersion": 2
    },
