      "webhookId": "34abb3bc-aef1-497e-8d81-9b01e6e2f589",
      "parameters": {
        "text": "=⏰ *Appointment Reminder – Tomorrow*\n\n👤 *Patient:* {{ $json['Patient Name'] }}\n📞 *Phone:* {{ $json['Patient Phone'] }}\n📧 *Email:* {{ $json['Patient Email'] }}\n📅 *Date:* {{ $json['Appointment Date'] }}\n⏰ *Time:* {{ $json['Appointment Time'] }}\n📋 *Reason:* {{ $json['Reason'] }}\n🔖 *Booking ID:* {{ $json['Booking ID'] }}\n\nPlease confirm attendance or reschedule.",
        "chatId": "={{ $json['Doctor Chat ID'] }}",
