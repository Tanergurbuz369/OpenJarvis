      "type": "n8n-nodes-base.stickyNote",
      "position": [
        -240,
        288
      ],
      "parameters": {
        "color": 7,
        "width": 452,
        "height": 212,
        "content": "### 1️⃣ Trigger\nFires on every incoming WhatsApp message. Connect your WhatsApp Business Cloud number here. Verify the payload field names match your account (some WhatsApp Business accounts nest fields slightly differently)."
      },
      "typeVersion": 1
    },
    {
      "id": "a0622862-82f0-4d9c-a803-2116a200677a",
