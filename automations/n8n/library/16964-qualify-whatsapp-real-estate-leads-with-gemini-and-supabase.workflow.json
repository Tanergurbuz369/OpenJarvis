      "parameters": {
        "color": 7,
        "width": 420,
        "height": 196,
        "content": "### 2️⃣ AI Classification\nGemini reads the WhatsApp message and extracts structured lead data (budget, property type, timeline, intent score 1–10). Edit the prompt below to match your listing categories or add fields."
      },
      "typeVersion": 1
