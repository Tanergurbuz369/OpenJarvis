    {
      "id": "99a52fcb-2112-4f87-8e74-cf9036687522",
      "name": "Parse Price Data",
      "type": "n8n-nodes-base.code",
      "position": [
        896,
        448
      ],
      "parameters": {
        "jsCode": "// Loop over all input items\nfor (const item of $input.all()) {\n  // Get the text field (defaulting to empty string if missing)\n  const text = item.json.text || \"\";\n\n  // Use Regular Expressions to find the values\n  const variantIdMatch = text.match(/Variant id:\\s*(\\d+)/i);\n  const rawCogsMatch = text.match(/Raw COGS:\\s*([\\d.]+)/i);\n  const landedCogsMatch = text.match(/Landed Cogs:\\s*([\\d.]+)/i);\n  const newPriceMatch = text.match(/New Price:\\s*([\\d.]+)/i);\n\n  // Attach the extracted data to the item's JSON\n  item.json.extracted = {\n    variantId: variantIdMatch ? variantIdMatch[1] : null,\n    rawCogs: rawCogsMatch ? parseFloat(rawCogsMatch[1]) : null,\n    landedCogs: landedCogsMatch ? parseFloat(landedCogsMatch[1]) : null,\n    newPrice: newPriceMatch ? parseFloat(newPriceMatch[1]) : null\n  };\n}\n\n// Return the modified items\nreturn $input.all();"
      },
      "typeVersion": 2
    },
