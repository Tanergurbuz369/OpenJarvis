    {
      "id": "1bd42e0b-9461-4535-993b-ae1d81b76fa0",
      "name": "Calculate New Prices",
      "type": "n8n-nodes-base.code",
      "position": [
        1344,
        112
      ],
      "parameters": {
        "jsCode": "// 1. Grab your global variables from the Edit Fields node! \n// (We divide by 100 to turn 35 into 0.35 for the math)\n// FIXED: Renamed to target the exact node name in your workflow\nconst prefs = $('Set Pricing Constants').first().json;\nconst hiddenCostPercent = prefs.hidden_cost_percentage / 100; \nconst targetMargin = prefs.profit_margin_percentage / 100;    \n\n// 2. Reach back to grab the original recipe (quantities and variant IDs)\n// This node name matches your workflow perfectly.\nconst dependencies = $('Fetch Product Dependencies').all().map(item => item.json);\n\n// 3. Grab the live prices from your Aggregate node\nconst livePrices = $('Merge Price Data').first().json.data;\n\n// 4. Clean up the supplier prices (remove \"/kg\" or \"/unit\")\nconst priceMap = {};\nfor (const item of livePrices) {\n    const rawNumber = parseFloat(item.todays_price.replace(/[^0-9.]/g, ''));\n    priceMap[item.sku_id] = rawNumber;\n}\n\n// 5. Calculate the Raw COGS (Cost of Goods Sold)\nlet variantCosts = {};\n\nfor (const dep of dependencies) {\n    const variantId = dep.shopify_variant_id;\n    const sku = dep.supplier_raw_sku;\n    const qty = dep.qty_required;\n\n    const currentUnitCost = priceMap[sku] || 0; \n    const ingredientCost = currentUnitCost * qty; \n\n    if (!variantCosts[variantId]) {\n        variantCosts[variantId] = 0;\n    }\n    variantCosts[variantId] += ingredientCost;\n}\n\n// 6. Apply Preferences and Calculate Final Price\nconst finalShopifyUpdates = [];\n\nfor (const [variantId, rawCogs] of Object.entries(variantCosts)) {\n    \n    // A. Calculate Hidden Costs & Landed COGS\n    const hiddenCosts = rawCogs * hiddenCostPercent;\n    const landedCogs = rawCogs + hiddenCosts;\n\n    // B. Calculate True Margin Final Price\n    // Formula: Final Price = Cost / (1 - Target Margin)\n    const finalRetailPrice = landedCogs / (1 - targetMargin);\n\n    // C. Package it for Shopify\n    finalShopifyUpdates.push({\n        json: {\n            variant_id: variantId,\n            raw_cogs: Math.round(rawCogs * 100) / 100,             \n            landed_cogs: Math.round(landedCogs * 100) / 100,       \n            new_price: Math.round(finalRetailPrice * 100) / 100    \n        }\n    });\n}\n\nreturn finalShopifyUpdates;"
      },
      "typeVersion": 2
    },
