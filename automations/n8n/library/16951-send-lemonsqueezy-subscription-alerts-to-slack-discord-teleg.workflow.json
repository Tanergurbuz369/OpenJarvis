              "id": "5ce332f6-aa4c-4308-839e-fcc13e252f32",
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              },
              "leftValue": "={{ $json.alert }}",
              "rightValue": ""
            }
          ]
        }
      },
      "typeVersion": 2.3
    },
