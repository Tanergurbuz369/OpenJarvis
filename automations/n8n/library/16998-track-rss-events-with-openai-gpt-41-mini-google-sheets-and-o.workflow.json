      "parameters": {
        "text": "=You are given an RSS feed item in JSON format. \nExtract and return the following fields in a structured way:\ncreator-{{ $json.creator }}\n- Title of the event{{ $json.title }}\n- Event date and time{{ $json.content }}\n- URL{{ $json.link }}\n- Content snippet- {{ $json.contentSnippet }}\n- Short description (if available)\n\nReturn the output as a JSON object with keys: \n\"title\", \"date_time\", \"url\", \"description\".\n",
        "options": {},
        "promptType": "define"
      },
      "typeVersion": 2.2,
      "alwaysOutputData": true
    },
