    {
      "id": "f217a4d1-e330-4548-866a-d8a814e58e57",
      "name": "PrepareTempoPayload",
      "type": "n8n-nodes-base.code",
      "position": [
        896,
        -256
      ],
      "parameters": {
        "jsCode": "// Tempo API Configuration\nconst TEMPO_AUTHOR_ID = \"YOUR_TEMPO_AUTHOR_ID\";\n\n/**\n * Prepares the payload for Tempo API submission.\n * @param {Object} item - The raw data item.\n * @returns {Object} - Formatted payload compliant with Tempo API.\n */\nconst prepareTempoPayload = (item) => {\n  const { id, fields } = item.json;\n\n  // Converts \"HH:MM\" format to total seconds\n  const toSeconds = (timeStr) => {\n    const [hours, minutes] = timeStr.split(\":\").map(Number);\n    return hours * 3600 + minutes * 60;\n  };\n\n  return {\n    json: {\n      authorAccountId: TEMPO_AUTHOR_ID,\n      issueId: id,\n      timeSpentSeconds: toSeconds(fields.endTime) - toSeconds(fields.startTime),\n      startDate: fields.date,\n      startTime: `${fields.startTime}:00`, // Ensure HH:MM:SS format\n      description: fields.description,\n    },\n  };\n};\n\n// Map items to the prepared payload structure\nreturn items.map(prepareTempoPayload);\n"
      },
      "typeVersion": 2
    }
