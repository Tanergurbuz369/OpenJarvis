    {
      "id": "44444444-4444-4444-8444-444444444415",
      "name": "Verify Duplicate Review",
      "type": "n8n-nodes-base.code",
      "position": [
        1040,
        320
      ],
      "parameters": {
        "jsCode": "const review = $('Extract Review Content').first().json;\nconst rows = $input.all();\n\nconst isDuplicate = rows.some((item) => {\n  const row = item.json;\n  const existingMessageId = row['Message ID'] || row.messageId || row.MessageId || '';\n  return existingMessageId && review.messageId && existingMessageId === review.messageId;\n});\n\nreturn [\n  {\n    json: {\n      ...review,\n      isDuplicate,\n    },\n  },\n];"
      },
      "typeVersion": 2
    },
    {
      "id": "44444444-4444-4444-8444-444444444416",
      "name": "If Review is New",
      "type": "n8n-nodes-base.if",
      "position": [
        1300,
        320
      ],
      "parameters": {
        "options": {},
        "conditions": {
          "options": {
            "version": 2,
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "is-new-review-check",
              "operator": {
                "type": "boolean",
                "operation": "equals"
              },
              "leftValue": "={{ $json.isDuplicate }}",
              "rightValue": false
            },
            {
              "id": "has-review-text-check",
              "operator": {
                "type": "number",
                "operation": "gt"
              },
              "leftValue": "={{ ($json.reviewText || '').length }}",
              "rightValue": 10
            }
          ]
        }
      },
      "typeVersion": 2.2
    },
    {
      "id": "44444444-4444-4444-8444-444444444417",
      "name": "OpenAI Review Classifier",
      "type": "n8n-nodes-base.openAi",
      "position": [
        1560,
        320
      ],
      "parameters": {
        "modelId": {
          "__rl": true,
          "mode": "list",
          "value": "gpt-4o-mini"
        },
        "options": {
          "temperature": 0.2
        },
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You analyze ecommerce product reviews. Return ONLY valid JSON with these keys: sentiment (positive|neutral|negative), score (number from -1 to 1), urgency (low|medium|high), themes (array of short strings), summary (one sentence), suggestedAction (one sentence for the support team). Be strict: angry 1-2 star reviews are negative with high urgency."
            },
            {
              "role": "user",
              "content": "=Product: {{ $('Verify Duplicate Review').item.json.productName }}\nStar rating: {{ $('Verify Duplicate Review').item.json.starRating || 'unknown' }}/5\nCustomer: {{ $('Verify Duplicate Review').item.json.customerName }}\nReview text:\n{{ $('Verify Duplicate Review').item.json.reviewText }}"
            }
          ]
        },
        "resource": "text",
        "operation": "message"
      },
      "credentials": {
        "openAiApi": {
          "name": "OpenAI account"
        }
      },
      "typeVersion": 1.8
    },
    {
      "id": "44444444-4444-4444-8444-444444444418",
      "name": "Parse AI Classification",
      "type": "n8n-nodes-base.code",
      "position": [
        1820,
        320
      ],
      "parameters": {
        "jsCode": "const review = $('Verify Duplicate Review').first().json;\nconst aiItem = $input.first().json;\n\nconst raw =\n  aiItem.message?.content ||\n  aiItem.text ||\n  aiItem.output ||\n  aiItem.choices?.[0]?.message?.content ||\n  '';\n\nlet analysis = {\n  sentiment: 'neutral',\n  score: 0,\n  urgency: 'low',\n  themes: [],\n  summary: 'Review received',\n  suggestedAction: 'Review manually',\n};\n\ntry {\n  const jsonMatch = String(raw).match(/\\{[\\s\\S]*\\}/);\n  if (jsonMatch) {\n    analysis = { ...analysis, ...JSON.parse(jsonMatch[0]) };\n  }\n} catch (error) {\n  const lowered = String(raw).toLowerCase();\n  if (lowered.includes('negative')) analysis.sentiment = 'negative';\n  else if (lowered.includes('positive')) analysis.sentiment = 'positive';\n}\n\nif (!Array.isArray(analysis.themes)) {\n  analysis.themes = String(analysis.themes || '')\n    .split(',')\n    .map((item) => item.trim())\n    .filter(Boolean);\n}\n\nconst starRating = review.starRating;\nconst threshold = review.urgentStarThreshold ?? 2;\n\nlet route = 'neutral';\nlet slackChannel = '';\nlet notifySlack = false;\n\nif (analysis.sentiment === 'negative') {\n  const lowStars = typeof starRating === 'number' && starRating <= threshold;\n  const highUrgency = analysis.urgency === 'high' || Number(analysis.score) <= -0.6;\n\n  if (lowStars || highUrgency) {\n    route = 'urgent';\n    slackChannel = review.slackChannelUrgent;\n    notifySlack = true;\n  } else {\n    route = 'negative';\n    slackChannel = review.slackChannelNegative;\n    notifySlack = true;\n  }\n} else if (analysis.sentiment === 'positive') {\n  route = 'positive';\n  slackChannel = review.slackChannelPositive;\n  notifySlack = true;\n}\n\nreturn [\n  {\n    json: {\n      ...review,\n      sentiment: analysis.sentiment,\n      score: analysis.score,\n      urgency: analysis.urgency,\n      themes: analysis.themes.join(', '),\n      summary: analysis.summary,\n      suggestedAction: analysis.suggestedAction,\n      route,\n      slackChannel,\n      notifySlack,\n    },\n  },\n];"
      },
      "typeVersion": 2
    },
    {
