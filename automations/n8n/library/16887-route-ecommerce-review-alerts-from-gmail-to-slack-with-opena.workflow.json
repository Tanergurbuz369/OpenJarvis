                },
                "combinator": "and",
                "conditions": [
                  {
                    "id": "route-neutral",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    },
                    "leftValue": "={{ $json.route }}",
                    "rightValue": "neutral"
                  }
                ]
              },
              "renameOutput": true
            }
          ]
        },
        "options": {
          "fallbackOutput": "none"
        }
      },
      "typeVersion": 3.2
    },
    {
      "id": "44444444-4444-4444-8444-444444444420",
      "name": "Prepare Slack Message",
      "type": "n8n-nodes-base.code",
      "position": [
        2360,
        240
      ],
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\nconst stars =\n  typeof item.starRating === 'number' ? `${item.starRating}/5` : 'Not detected';\n\nconst routeEmoji = {\n  urgent: '🚨',\n  negative: '⚠️',\n  positive: '🎉',\n};\n\nconst emoji = routeEmoji[item.route] || '📝';\nconst headline =\n  item.route === 'urgent'\n    ? 'Urgent review needs response'\n    : item.route === 'negative'\n      ? 'New negative review'\n      : item.route === 'positive'\n        ? 'New positive review'\n        : 'New review logged';\n\nconst text = [\n  `${emoji} *${headline}*`,\n  `*Product:* ${item.productName}`,\n  `*Customer:* ${item.customerName}`,\n  `*Rating:* ${stars}`,\n  `*Sentiment:* ${item.sentiment} (${item.urgency} urgency)`,\n  `*Summary:* ${item.summary}`,\n  `*Themes:* ${item.themes || 'n/a'}`,\n  `*Suggested action:* ${item.suggestedAction}`,\n  '',\n  `> ${item.reviewText.slice(0, 500)}`,\n].join('\\n');\n\nreturn [\n  {\n    json: {\n      ...item,\n      text,\n      channel: item.slackChannel,\n    },\n  },\n];"
      },
      "typeVersion": 2
    },
