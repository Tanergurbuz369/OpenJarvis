    {
      "id": "44444444-4444-4444-8444-444444444412",
      "name": "Setup Alert Configuration",
      "type": "n8n-nodes-base.code",
      "position": [
        260,
        320
      ],
      "parameters": {
        "jsCode": "// ===== EDIT YOUR SETTINGS HERE =====\nconst GOOGLE_SHEET_ID = 'your-google-sheet-id';\nconst SHEET_NAME = 'Reviews';\n\nconst SLACK_CHANNEL_URGENT = '#review-escalations';\nconst SLACK_CHANNEL_NEGATIVE = '#customer-reviews';\nconst SLACK_CHANNEL_POSITIVE = '#review-wins';\n\n// Reviews at or below this star count can be escalated when sentiment is negative.\nconst URGENT_STAR_THRESHOLD = 2;\n\nconst email = $input.first().json;\n\nreturn [\n  {\n    json: {\n      googleSheetId: GOOGLE_SHEET_ID,\n      sheetName: SHEET_NAME,\n      slackChannelUrgent: SLACK_CHANNEL_URGENT,\n      slackChannelNegative: SLACK_CHANNEL_NEGATIVE,\n      slackChannelPositive: SLACK_CHANNEL_POSITIVE,\n      urgentStarThreshold: URGENT_STAR_THRESHOLD,\n      email,\n    },\n  },\n];"
      },
      "typeVersion": 2
    },
    {
      "id": "44444444-4444-4444-8444-444444444413",
      "name": "Extract Review Content",
      "type": "n8n-nodes-base.code",
      "position": [
        520,
        320
      ],
      "parameters": {
        "jsCode": "const settings = $input.first().json;\nconst email = settings.email || {};\n\nconst subject = email.subject || '';\nconst body = email.textPlain || email.text || email.snippet || '';\nconst combined = `${subject}\\n${body}`;\nconst messageId = email.id || email.messageId || '';\nconst receivedAt = email.date || new Date().toISOString();\n\nconst fromValue = email.from?.value?.[0] || email.from || {};\nconst senderEmail =\n  typeof fromValue === 'string'\n    ? fromValue.match(/[\\w.+-]+@[\\w.-]+\\.\\w+/)?.[0] || fromValue\n    : fromValue.address || '';\nconst senderName =\n  typeof fromValue === 'string'\n    ? fromValue.replace(senderEmail, '').replace(/[<>\",]/g, '').trim()\n    : fromValue.name || 'Unknown customer';\n\nlet starRating = null;\nconst starPatterns = [\n  /(\\d)\\s*(?:out of|\\/)\\s*5/i,\n  /(\\d)\\s*star review/i,\n  /rated\\s*(?:it\\s*)?(\\d)\\s*\\/\\s*5/i,\n  /rating[:\\s]+(\\d)/i,\n  /(\\d)\\s*★/,\n  /★{1,5}/,\n];\n\nfor (const pattern of starPatterns) {\n  const match = combined.match(pattern);\n  if (!match) continue;\n\n  if (match[0].includes('★')) {\n    starRating = match[0].length;\n    break;\n  }\n\n  const parsed = Number(match[1]);\n  if (!Number.isNaN(parsed) && parsed >= 1 && parsed <= 5) {\n    starRating = parsed;\n    break;\n  }\n}\n\nconst productPatterns = [\n  /product[:\\s]+(.+?)(?:\\n|$)/i,\n  /for\\s+(.+?)\\s+on/i,\n  /review(?:ed)?\\s+(.+?)(?:\\.|\\n|$)/i,\n];\n\nlet productName = '';\nfor (const pattern of productPatterns) {\n  const match = combined.match(pattern);\n  if (match?.[1]) {\n    productName = match[1].trim().slice(0, 120);\n    break;\n  }\n}\n\nif (!productName) {\n  productName = subject.replace(/review|notification|alert/gi, '').trim() || 'Unknown product';\n}\n\nconst quotedReview = body.match(/\"([^\"]{10,})\"/);\nconst reviewText = quotedReview\n  ? quotedReview[1].trim()\n  : body\n      .replace(/^(hi|hello|dear).+?\\n/i, '')\n      .replace(/unsubscribe.*/is, '')\n      .trim()\n      .slice(0, 1500);\n\nreturn [\n  {\n    json: {\n      googleSheetId: settings.googleSheetId,\n      sheetName: settings.sheetName,\n      slackChannelUrgent: settings.slackChannelUrgent,\n      slackChannelNegative: settings.slackChannelNegative,\n      slackChannelPositive: settings.slackChannelPositive,\n      urgentStarThreshold: settings.urgentStarThreshold,\n      messageId,\n      receivedAt,\n      customerName: senderName,\n      customerEmail: senderEmail,\n      productName,\n      starRating,\n      reviewText,\n      emailSubject: subject,\n    },\n  },\n];"
      },
      "typeVersion": 2
    },
