    {
      "id": "371fdbe8-28d5-49df-8ae8-d90341d23539",
      "name": "Create Shopify collection",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        -1296,
        32
      ],
      "parameters": {
        "url": "={{ $('Configure store settings').item.json.shopify_url }}/admin/api/{{ $('Configure store settings').item.json.shopify_api_version }}/graphql.json",
        "method": "POST",
        "options": {},
        "jsonBody": "={{ JSON.stringify({ query: `mutation collectionCreate($input: CollectionInput!) { collectionCreate(input: $input) { collection { id title handle description } userErrors { field message } } }`, variables: (() => { const src = ($json.image?.src ?? '').trim(); const input = { title: $json.title ?? '', descriptionHtml: $json.content ?? '', handle: $json.url ?? '', seo: { title: $json.fulltitle ?? '', description: $json.description ?? '' } }; if (src) input.image = { src }; return { input }; })() }) }}",
        "sendBody": true,
        "specifyBody": "json",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth"
      },
