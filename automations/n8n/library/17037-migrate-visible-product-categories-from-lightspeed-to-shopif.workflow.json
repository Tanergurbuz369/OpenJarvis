        "jsonBody": "={{ JSON.stringify({query:'mutation urlRedirectCreate($urlRedirect: UrlRedirectInput!) { urlRedirectCreate(urlRedirect: $urlRedirect) { urlRedirect { id path target } userErrors { field message } } }',variables:{urlRedirect:{path:$('Process each category').item.json.url,target:'/collections/'+$json.data.collectionCreate.collection.handle}}}) }}",
        "sendBody": true,
